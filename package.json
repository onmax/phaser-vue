{
  "name": "phaser-vue-monorepo",
  "type": "module",
  "version": "0.0.1-alpha.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @onmax/phaser-vue build && pnpm --filter @onmax/nuxt-phaser build",
    "dev:docs": "pnpm --filter docs dev",
    "dev:playground": "pnpm --filter playground dev",
    "dev:example:minimal": "pnpm --filter @examples/vue-minimal dev",
    "dev:example:imperative": "pnpm --filter @examples/vue-imperative-escape-hatch dev",
    "dev:example:multi-scene": "pnpm --filter @examples/vue-multi-scene dev",
    "lint": "eslint . --ignore-pattern docs/.output --ignore-pattern playground/.output --ignore-pattern '**/dist/**'",
    "lint:fix": "eslint . --fix --ignore-pattern docs/.output --ignore-pattern playground/.output --ignore-pattern '**/dist/**'",
    "typecheck": "pnpm --filter @onmax/phaser-vue typecheck && pnpm --filter @onmax/nuxt-phaser typecheck && pnpm --filter playground typecheck",
    "test": "pnpm --filter @onmax/phaser-vue test && pnpm --filter @onmax/nuxt-phaser test",
    "docs:build": "pnpm --filter docs build",
    "playground:build": "pnpm --filter playground build",
    "vercel:build:docs": "rm -rf .vercel/output && pnpm --filter docs build && cp -r docs/.vercel/output .vercel/output",
    "vercel:build:playground": "rm -rf .vercel/output && pnpm --filter playground build && cp -r playground/.vercel/output .vercel/output",
    "validate:packages": "pnpm build && publint packages/vue && publint packages/nuxt",
    "preview:packages": "mkdir -p .artifacts && pnpm --filter @onmax/phaser-vue pack --pack-destination .artifacts && pnpm --filter @onmax/nuxt-phaser pack --pack-destination .artifacts",
    "prepack": "pnpm validate:packages"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@nuxt/content": "catalog:",
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/eslint-config": "catalog:lint",
    "@nuxt/fonts": "catalog:",
    "@nuxt/kit": "catalog:prod",
    "@nuxt/module-builder": "catalog:build",
    "@nuxt/test-utils": "catalog:test",
    "@testing-library/vue": "catalog:test",
    "@types/node": "catalog:types",
    "@vitest/browser-playwright": "catalog:test",
    "@vercel/analytics": "catalog:",
    "@vercel/speed-insights": "catalog:",
    "@vitejs/plugin-vue": "catalog:vite",
    "@vue/test-utils": "catalog:test",
    "@vueuse/core": "catalog:",
    "docus": "catalog:",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "jsdom": "catalog:test",
    "nuxt": "catalog:",
    "phaser": "catalog:prod",
    "publint": "catalog:build",
    "tailwindcss": "catalog:",
    "typescript": "catalog:build",
    "vite": "catalog:vite",
    "vite-plugin-dts": "catalog:build",
    "vitest": "catalog:test",
    "vue": "catalog:vue",
    "vue-tsc": "catalog:types",
    "zod": "catalog:",
    "zod-to-json-schema": "catalog:"
  }
}
